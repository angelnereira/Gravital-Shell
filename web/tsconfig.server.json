{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".next/server-build",
    "resolveJsonModule": true
  },
  "include": ["server/**/*.ts", "lib/**/*.ts"]
}
